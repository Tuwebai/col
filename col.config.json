{
  "entrypoints": [],
  "ignore": [
    "**/node_modules/**",
    "**/dist/**",
    "**/.git/**",
    "**/coverage/**"
  ],
  "maxFiles": 5,
  "maxLinesPerFile": 120,
  "maxTotalLines": 240,
  "matchWindow": 20,
  "packCacheTtlMs": 3600000,
  "domainMappings": [
    {
      "name": "auth",
      "aliases": ["auth", "authentication", "login", "session"],
      "paths": ["src/features/auth/", "src/core/auth/", "src/auth/"],
      "tags": ["auth", "login", "session"],
      "boost": 20
    },
    {
      "name": "api",
      "aliases": ["api", "http", "endpoint", "client"],
      "paths": ["src/features/api/", "src/core/api/", "src/api/"],
      "tags": ["api", "http", "client"],
      "boost": 18
    },
    {
      "name": "cli",
      "aliases": ["cli", "command", "terminal"],
      "paths": ["src/cli/", "extension/src/cli/"],
      "tags": ["cli", "command"],
      "boost": 20
    }
  ],
  "domainRules": [
    {
      "name": "docs",
      "matchTags": ["docs", "md"],
      "matchPaths": ["docs/"],
      "boost": 2
    },
    {
      "name": "source",
      "matchTags": ["src", "ts", "tsx", "js"],
      "matchPaths": ["src/"],
      "boost": 3
    }
  ],
  "toolLimits": {
    "searchMatches": 8,
    "diffFiles": 6,
    "logLines": 80
  }
}
