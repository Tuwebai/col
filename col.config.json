{
  "entrypoints": [],
  "ignore": [
    "node_modules/**",
    "dist/**",
    ".git/**",
    "coverage/**"
  ],
  "maxFiles": 5,
  "maxLinesPerFile": 120,
  "matchWindow": 20,
  "domainRules": [
    {
      "name": "docs",
      "matchTags": ["docs", "md"],
      "matchPaths": ["docs/"],
      "boost": 2
    },
    {
      "name": "source",
      "matchTags": ["src", "ts", "tsx", "js"],
      "matchPaths": ["src/"],
      "boost": 3
    }
  ],
  "toolLimits": {
    "searchMatches": 8,
    "diffFiles": 6,
    "logLines": 80
  }
}
